# Server
PORT=3000
NODE_ENV=production

# Security - generate a random string with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# GitHub OAuth
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_CALLBACK_URL=https://dashboard.yourdomain.com/auth/github/callback

# Dashboard URL (used for redirects)
DASHBOARD_URL=https://dashboard.yourdomain.com

# Paths
DB_PATH=/data/data/com.termux/files/home/MiniShinobi/backend/db/minishinobi.sqlite
LOGS_DIR=/data/data/com.termux/files/home/MiniShinobi/logs
APPS_DIR=/data/data/com.termux/files/home/MiniShinobi/apps
RUNTIME_DIR=/data/data/com.termux/files/home/MiniShinobi/runtime
NGINX_SITES_ENABLED_DIR=/data/data/com.termux/files/home/MiniShinobi/nginx/sites-enabled

# Nginx + domains
BASE_DOMAIN=minishinobi.dev
NGINX_RELOAD_CMD=nginx -s reload

# Webhook auth
WEBHOOK_SECRET=replace-with-strong-secret

# Port range for deployed apps
APP_PORT_START=5000
APP_PORT_END=5999

# Build/deploy command guards (prevent stuck deployments)
BUILD_COMMAND_TIMEOUT_MS=1800000
BUILD_IDLE_TIMEOUT_MS=600000
BUILD_HEARTBEAT_MS=20000